# Shared
APP_ENV=development
LOG_LEVEL=INFO

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Backend
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000
DEFAULT_CHAT_TOP_K=5
DEFAULT_CHAT_TEMPERATURE=0.1
MAX_HISTORY_MESSAGES=8
INDEXER_BATCH_SIZE=24
KNOWLEDGE_BASE_PATH=data/knowledge_base
HR_DATABASE_PATH=data/hr.sqlite3
SQL_MAX_ROWS=25
MOCK_AZURE_MODE=true

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_API_KEY=replace-me
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AZURE_SEARCH_API_KEY=replace-me
AZURE_SEARCH_INDEX_NAME=hr-policy-index
